#!/usr/bin/env osascript -l JavaScript

/**
 * get-screen-context.jxa
 * 
 * macOS equivalent of get-screen-context.ps1.
 * Combines window listing with focused window UI tree for screen context.
 * 
 * Parameters:
 *   -FocusedProcessId <number>  - PID of the focused process (optional; auto-detects if omitted)
 *   -MaxDepth <number>          - Max depth for UI tree traversal (default: 2)
 * 
 * Returns JSON with:
 *   - windows: Array of visible windows with title, processName, processId, bounds
 *   - focusedWindow: Info about the focused window
 *   - uiTree: UI element tree of the focused window (up to MaxDepth)
 * 
 * Usage: osascript -l JavaScript get-screen-context.jxa
 *        osascript -l JavaScript get-screen-context.jxa -FocusedProcessId 1046 -MaxDepth 2
 */

function safeGet(obj, property, defaultValue) {
    try {
        var val = obj[property]();
        return val !== undefined && val !== null ? val : defaultValue;
    } catch (e) {
        return defaultValue;
    }
}

function getElementTree(element, maxDepth, currentDepth) {
    if (currentDepth > maxDepth) return null;
    
    var node = { role: '', name: '', value: '' };
    
    try { node.role = element.role() || ''; } catch (e) {}
    try { node.name = element.name() || ''; } catch (e) {}
    try { 
        var v = element.value();
        if (v !== undefined && v !== null) node.value = String(v);
    } catch (e) {}
    
    // Get bounds
    try {
        var pos = element.position();
        var sz = element.size();
        node.bounds = {
            x: pos[0] || 0,
            y: pos[1] || 0,
            width: sz[0] || 0,
            height: sz[1] || 0
        };
    } catch (e) {}
    
    // Get children
    if (currentDepth < maxDepth) {
        try {
            var children = element.uiElements();
            if (children.length > 0) {
                node.children = [];
                for (var i = 0; i < children.length && i < 50; i++) {
                    var child = getElementTree(children[i], maxDepth, currentDepth + 1);
                    if (child) node.children.push(child);
                }
            }
        } catch (e) {}
    }
    
    return node;
}

function run(argv) {
    try {
        // Parse arguments
        var focusedProcessId = null;
        var maxDepth = 2;
        
        for (var i = 0; i < argv.length; i++) {
            if ((argv[i] === '-FocusedProcessId' || argv[i] === '-processId') && i + 1 < argv.length) {
                focusedProcessId = parseInt(argv[++i], 10);
            } else if ((argv[i] === '-MaxDepth' || argv[i] === '-maxDepth') && i + 1 < argv.length) {
                maxDepth = parseInt(argv[++i], 10);
            }
        }
        
        var SystemEvents = Application('System Events');
        SystemEvents.includeStandardAdditions = true;
        
        var result = {
            windows: [],
            focusedWindow: null,
            uiTree: null
        };
        
        // 1. Get all visible windows
        var processes = SystemEvents.processes.where({ backgroundOnly: false });
        
        var focusedProcess = null;
        
        for (var p = 0; p < processes.length; p++) {
            try {
                var process = processes[p];
                var processName = safeGet(process, 'name', 'unknown');
                var processId = safeGet(process, 'unixId', 0);
                var isFrontmost = safeGet(process, 'frontmost', false);
                
                // Track focused process
                if (isFrontmost || (focusedProcessId && processId === focusedProcessId)) {
                    focusedProcess = process;
                    if (!focusedProcessId) focusedProcessId = processId;
                }
                
                var windows = process.windows;
                for (var w = 0; w < windows.length; w++) {
                    try {
                        var win = windows[w];
                        var title = '';
                        try { title = win.name() || ''; } catch (e) {}
                        
                        if (!title || title.trim().length === 0) continue;
                        
                        var bounds = { x: 0, y: 0, width: 0, height: 0 };
                        try {
                            var position = win.position();
                            var size = win.size();
                            bounds = {
                                x: position[0],
                                y: position[1],
                                width: size[0],
                                height: size[1]
                            };
                        } catch (e) {}
                        
                        var isMinimized = false;
                        try { isMinimized = win.miniaturized(); } catch (e) {}
                        
                        var winInfo = {
                            title: title,
                            processName: processName,
                            processId: processId,
                            bounds: bounds,
                            isMinimized: isMinimized,
                            isFocused: isFrontmost
                        };
                        
                        result.windows.push(winInfo);
                        
                        // Capture focused window info
                        if ((isFrontmost || processId === focusedProcessId) && !result.focusedWindow) {
                            result.focusedWindow = winInfo;
                        }
                    } catch (e) {}
                }
            } catch (e) {}
        }
        
        // 2. Get UI tree for focused window
        if (focusedProcess) {
            try {
                var focusedWindows = focusedProcess.windows;
                if (focusedWindows.length > 0) {
                    result.uiTree = getElementTree(focusedWindows[0], maxDepth, 0);
                }
            } catch (e) {
                result.uiTree = { error: e.toString() };
            }
        }
        
        return JSON.stringify(result);
        
    } catch (error) {
        return JSON.stringify({ error: error.toString() });
    }
}
